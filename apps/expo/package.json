{
  "name": "@acme/expo",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules plugins/build",
    "dev": "expo start --ios --clear",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:plugins": "tsc --project plugins/tsconfig.json",
    "prebuild": "pnpm build:plugins && expo prebuild && npx tsx scripts/copy-live-activity-templates.ts",
    "prebuild:clean": "pnpm build:plugins && expo prebuild --clean && npx tsx scripts/copy-live-activity-templates.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bacons/apple-targets": "^3.0.7",
    "@better-auth/expo": "catalog:",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@legendapp/list": "^2.0.14",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "babel-plugin-inline-import": "^3.0.0",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "expo": "~54.0.31",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "^14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-live-activity": "^0.4.2",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "^16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.1.23",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.69.0",
    "react-native": "~0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.3",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "~0.5.1",
    "superjson": "2.2.3",
    "zod": "catalog:",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@acme/api": "workspace:*",
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tailwind-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@expo/config-plugins": "~54.0.4",
    "@types/react": "catalog:react19",
    "drizzle-kit": "^0.31.5",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "~3.4.17",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "^4.0.16"
  },
  "prettier": "@acme/prettier-config"
}
